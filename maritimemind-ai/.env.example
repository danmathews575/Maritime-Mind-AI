# ============================================================
# MaritimeMind AI — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ── LLM Provider ─────────────────────────────────────────────
# Primary provider (first to try)
# Options: nvidia | gemini | ollama | openai
LLM_PROVIDER=nvidia

# Fallback chain (comma-separated, tried in order if previous fails)
# Example: nvidia,gemini,ollama means:
#   1st try NVIDIA NIM → 2nd try Gemini → 3rd try Ollama (local)
LLM_FALLBACK_ORDER=nvidia,gemini,ollama

# NVIDIA NIM API (primary — cloud inference)
NVIDIA_API_KEY=your_nvidia_nim_key_here

# Google Gemini (secondary fallback — no local GPU required)
# Supports comma-separated keys for automatic rate-limit rotation
GEMINI_API_KEY=your_gemini_key_here

# OpenAI (optional, not in default fallback chain)
OPENAI_API_KEY=your_openai_key_here

# Ollama (tertiary fallback — local, requires Ollama running)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# ── Vector Store (Qdrant) ────────────────────────────────────
# Set QDRANT_HOST=local for file-based mode (no separate service needed)
# Set QDRANT_HOST=localhost (or container name) for server mode
QDRANT_HOST=local
QDRANT_PATH=./vector_store/qdrant_local
QDRANT_PORT=6333

# ── BM25 Sparse Index ────────────────────────────────────────
BM25_INDEX_PATH=./vector_store/bm25_index.pkl

# ── Redis Cache ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Retrieval Tuning ─────────────────────────────────────────
# Minimum confidence score (0.0–1.0) before issuing a refusal
CONFIDENCE_THRESHOLD=0.6

# Number of chunks to retrieve per query
TOP_K_RESULTS=5

# ── Authentication ───────────────────────────────────────────
# IMPORTANT: Change JWT_SECRET_KEY before any production deployment
JWT_SECRET_KEY=change_this_to_a_strong_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Embedding Dimensions ─────────────────────────────────────
# Do not change unless you swap the embedding models
TEXT_EMBEDDING_DIM=768
IMAGE_EMBEDDING_DIM=512

# ── Data Paths ───────────────────────────────────────────────
EXTRACTED_IMAGES_DIR=./data/extracted_images

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated allowed origins for the API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
