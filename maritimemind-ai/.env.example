# LLM Inference
# Choose between: ollama, gemini, or openai
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# External API Keys (Required if LLM_PROVIDER is gemini or openai)
# You can provide multiple keys separated by commas for load balancing / rate limit rotation.
GEMINI_API_KEY=key1,key2
OPENAI_API_KEY=your_openai_api_key_here

# Vector Store
CHROMADB_PERSIST_DIR=./vector_store/chromadb
BM25_INDEX_PATH=./vector_store/bm25_index.pkl

# Retrieval Thresholds
CONFIDENCE_THRESHOLD=0.3

# Authentication
JWT_SECRET_KEY=supersecretkey_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Vector Embeddings
TEXT_EMBEDDING_DIM=384
IMAGE_EMBEDDING_DIM=512

# Frontend Config
VITE_API_URL=http://localhost:8000
